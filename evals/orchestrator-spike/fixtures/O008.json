      "kind": "regex",
      "pattern": "(?i)(pr-comment-responder|skill.*first|invoke.*skill|delegate|matching.*skill)"
    }
  ],
  "tags": [
    "agent-orchestrator",
    "ai-agents-pattern",
    "verdict-identify",
    "agent-discriminating"
  ]
