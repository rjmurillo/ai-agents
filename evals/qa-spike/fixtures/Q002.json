{
  "schemaVersion": 1,
  "id": "Q002",
  "policy_id": "pol-qa-status-claim-evidence",
  "input": "PR description: 'Coverage now 95.2%.' Diff has +120 src lines, +0 test lines. Verdict (and what evidence specifically would prove or refute the claim)?",
  "provenance": "synthetic",
  "assertions": [
    {
      "kind": "verdict",
      "expected_value": "IDENTIFY"
    },
    {
      "kind": "regex",
      "pattern": "(?i)(coverage.*tool.*output|pytest.*--cov|specific.*report|prove|refute|no.*test.*lines|cannot.*verify|specific.*tool|measure)"
    }
  ],
  "tags": [
    "agent-qa",
    "triad-aware",
    "verdict-identify",
    "agent-discriminating"
  ]
}
