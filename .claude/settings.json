{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/routing_gates.py",
            "timeout": 5,
            "statusMessage": "Checking routing-level gates (ADR-033)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/skill_first_guard.py",
            "statusMessage": "Enforcing skills-first policy for GitHub operations (BLOCKING)"
          }
        ]
      },
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/session_log_guard.py",
            "statusMessage": "Verifying session log exists before commit (BLOCKING)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/adr_review_guard.py",
            "statusMessage": "Verifying ADR review completed (MUST requirement)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/branch_protection_guard.py",
            "statusMessage": "Verifying branch protection"
          }
        ]
      },
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PreToolUse/branch_protection_guard.py",
            "statusMessage": "Verifying branch protection"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/SessionStart/session_initialization_enforcer.py",
            "statusMessage": "Enforcing session protocol initialization (BLOCKING)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/SessionStart/memory_first_enforcer.py",
            "statusMessage": "Enforcing ADR-007 memory-first evidence (HYBRID)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/session_start_memory_first.py",
            "statusMessage": "Enforcing ADR-007 memory-first requirements"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/adr_change_detection.py",
            "statusMessage": "Checking for ADR changes"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/UserPromptSubmit/autonomous_execution_detector.py",
            "statusMessage": "Detecting autonomous execution patterns"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/user_prompt_memory_check.py",
            "statusMessage": "Checking memory-first compliance"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Write|Edit)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PostToolUse/markdown_auto_lint.py",
            "statusMessage": "Auto-linting markdown files"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/Stop/invoke_skill_learning.py",
            "statusMessage": "Extracting skill learnings from session (LLM-enhanced)"
          },
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/Stop/session_validator.py",
            "statusMessage": "Validating session completeness"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/SubagentStop/qa_agent_validator.py",
            "statusMessage": "Validating QA agent output"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash(pytest*|python*pytest*|npm test*|npm run test*|pnpm test*|yarn test*|dotnet test*|mvn test*|gradle test*|go test*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -u .claude/hooks/PermissionRequest/test_auto_approval.py",
            "statusMessage": "Auto-approving test execution"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "forgetful@scottrbk": true,
    "context7@context7": true,
    "context-hub@scottrbk": true,
    "claude-router@claude-router-marketplace": true
  }
}
