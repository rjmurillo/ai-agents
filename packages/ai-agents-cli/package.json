{
  "name": "@rjmurillo/ai-agents",
  "version": "0.1.0",
  "description": "Vendor a curated Claude Code kit into any repo",
  "type": "module",
  "bin": {
    "ai-agents": "dist/cli.js"
  },
  "files": [
    "dist/",
    "bundle/assets/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target node --format esm && bun run scripts/build-bundle.ts",
    "test": "bun test",
    "lint": "bun run scripts/bundle-lint.ts"
  },
  "devDependencies": {
    "bun-types": "latest"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rjmurillo/ai-agents.git",
    "directory": "packages/ai-agents-cli"
  },
  "keywords": [
    "claude",
    "ai-agents",
    "claude-code",
    "developer-tools"
  ]
}
