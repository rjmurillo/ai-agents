{
  "name": "@rjmurillo/ai-agents",
  "version": "0.1.0",
  "description": "CLI to vendor a curated .claude/ kit into any repository",
  "type": "module",
  "bin": {
    "ai-agents": "dist/cli.js"
  },
  "files": [
    "dist/",
    "bundle/assets/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/cli.ts --target=node --outdir=dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "claude",
    "ai-agents",
    "cli",
    "developer-tools"
  ],
  "author": "Richard Murillo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rjmurillo/ai-agents.git",
    "directory": "packages/ai-agents-cli"
  },
  "bugs": {
    "url": "https://github.com/rjmurillo/ai-agents/issues"
  },
  "homepage": "https://github.com/rjmurillo/ai-agents#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
