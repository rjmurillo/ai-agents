{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "skill-output.schema.json",
  "title": "Skill Output Envelope",
  "description": "Standard envelope for all skill script outputs per ADR-051",
  "type": "object",
  "required": ["Success", "Metadata"],
  "properties": {
    "Success": {
      "type": "boolean",
      "description": "Whether the operation succeeded"
    },
    "Data": {
      "description": "Operation-specific result data (null on failure)"
    },
    "Error": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["Message", "Code"],
          "properties": {
            "Message": {
              "type": "string",
              "description": "Human-readable error message"
            },
            "Code": {
              "type": "integer",
              "description": "Exit code per ADR-035"
            },
            "Type": {
              "type": "string",
              "enum": ["NotFound", "ApiError", "AuthError", "InvalidParams", "Timeout", "General"],
              "description": "Machine-readable error category"
            }
          }
        }
      ]
    },
    "Metadata": {
      "type": "object",
      "required": ["Script", "Timestamp"],
      "properties": {
        "Script": {
          "type": "string",
          "description": "Name of the skill script"
        },
        "Version": {
          "type": "string",
          "description": "Script version"
        },
        "Timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp"
        }
      }
    }
  },
  "if": {
    "properties": { "Success": { "const": false } }
  },
  "then": {
    "required": ["Success", "Error", "Metadata"],
    "properties": {
      "Error": {
        "type": "object"
      }
    }
  }
}
